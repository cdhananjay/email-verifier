{
  "scripts": {
    "format-lint": "bunx --bun @biomejs/biome check --write src",
    "format-lint:check": "bunx --bun @biomejs/biome check src",
    "dev": "bun run --env-file=.env --watch src/index.js",
    "typecheck": "bunx --bun tsc --noEmit",
    "build": "bun install && bunx --bun prisma migrate deploy && bunx --bun prisma generate"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@types/node": "^26.0.0",
    "@types/pg": "^8.20.0",
    "prisma": "^7.8.0",
    "typescript": "^6.0.3"
  }
}